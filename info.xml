<?xml version="1.0"?>
<extension key="ai_assistant" type="module">
  <file>ai_assistant</file>
  <name>CiviCRM AI Assistant</name>
  <description>Provider-agnostic AI productivity features. Flagship: natural-language to SearchKit search with display-intent detection and iterative refinement.</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>Kurund Jalmi</name>
      <email>kurund.jalmi@gmail.com</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Licensing">https://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-06</releaseDate>
  <version>1.0.0</version>
  <develStage>alpha</develStage>
  <compatibility mode="semver">
    <comments>Semantic versioning. For example, compatibility with "6.1" implies compatibility with "6.2".</comments>
    <ver>6.17</ver>
  </compatibility>
  <php_compatibility mode="list">
    <comments>Listed versions. For example, specify both "8.1" and "8.2".</comments>
    <ver>8.0</ver>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
    <ver>8.4</ver>
  </php_compatibility>
  <smarty_compatibility mode="list">
    <comments>Listed versions. For example, specify both "4" and "5".</comments>
    <ver>5</ver>
  </smarty_compatibility>
  <comments>This is a new, undeveloped module</comments>
  <requires>
    <ext version="~5.0">org.civicrm.search_kit</ext>
  </requires>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/AiAssistant</namespace>
    <format>25.10.2</format>
    <angularModule>crmAiAssistant</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
    <mixin>menu-xml@1.0.0</mixin>
  </mixins>
</extension>
